# Gold FTE — local gitignore

# Secrets and credentials (NEVER push)
.env
.env.*
.secrets/
.state/

# Python artifacts
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Pytest
.pytest_cache/

# Vault runtime data (private)
AI_Employee_Vault/Logs/*.json
AI_Employee_Vault/Logs/*.log
AI_Employee_Vault/Done/*.md
AI_Employee_Vault/Needs_Action/*.md
AI_Employee_Vault/Pending_Approval/*.md
AI_Employee_Vault/Approved/*.md
AI_Employee_Vault/Rejected/*.md
AI_Employee_Vault/Plans/*.md
AI_Employee_Vault/Inbox/
AI_Employee_Vault/Drop_Box/

# Vault business-sensitive config (private)
AI_Employee_Vault/Business_Goals.md
AI_Employee_Vault/FAQ_Context.md

# MCP servers
mcp-email-server/node_modules/
mcp-email-server/.env
mcp-odoo-server/node_modules/
mcp-odoo-server/.env
mcp-social-server/node_modules/
mcp-social-server/.env

# Claude local settings (machine-specific)
.claude/settings.local.json

# OS artifacts
.DS_Store
Thumbs.db
*.tmp
*.swp

node_modules/
# Test checklist (contains live test data and timestamps)
GOLD_TIER_TEST_CHECKLIST.md
